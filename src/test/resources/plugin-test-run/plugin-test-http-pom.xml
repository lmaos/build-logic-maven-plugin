<project>
    <build>
        <plugins>
            <plugin>
                <groupId>com.clmcat.maven.plugins</groupId>
                <artifactId>build-logic-maven-plugin</artifactId>
                <version>1.0-SNAPSHOT</version>
                <configuration>
                    <main>
                        <http name="httpResult" url="http://www.baidu.com" method="GET"></http>
                        <echo>httpResult=${httpResult.code}</echo>
                        <echo>httpResult=${httpResult}</echo>

                        <http url="http://test.api.clmcat.com/api/" method="GET">
                            <response to="response">
                                <echo>${response}</echo>
                                <echo>${response.code}</echo>
                                <echo>${response.message}</echo>
                                <!-- Read header data: getHeader(String name); the type must be specified or an error will occur -->
                                <echo>${response.headers.getHeader(String "Content-Type")}</echo>
                            </response>
                        </http>
                    </main>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>