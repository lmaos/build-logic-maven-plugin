<project>
    <build>
        <plugins>
            <plugin>
                <groupId>com.clmcat.maven.plugins</groupId>
                <artifactId>build-logic-maven-plugin</artifactId>
                <version>1.0-SNAPSHOT</version>
                <configuration>
                    <main>
                        <http name="httpResult" url="http://127.0.0.1:18080/smoke/success" method="GET"></http>
                        <echo>httpResult=${httpResult.code}</echo>
                        <echo>httpResult=${httpResult}</echo>

                        <http url="http://127.0.0.1:18080/smoke/not-found" method="GET">
                            <response to="response">
                                <echo>${response}</echo>
                                <echo>${response.code}</echo>
                                <echo>${response.message}</echo>
                                <!-- 读取Header 中数据， getHeader(String name) , 必须要指定类型，否则会报错 -->
                                <echo>${response.headers.getHeader("Content-type")}</echo>
                            </response>
                        </http>
                    </main>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
