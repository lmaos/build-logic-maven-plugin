<project>
    <build>
        <plugins>
            <plugin>
                <groupId>com.clmcat.maven.plugins</groupId>
                <artifactId>build-logic-maven-plugin</artifactId>
                <version>1.0-SNAPSHOT</version>
                <configuration>
                    <main>
                        <file name="outputFile" path="${project.basedir}/regression-http-output.txt" />
                        <http url="http://127.0.0.1:18080/regression/headers" method="GET">
                            <response to="response">
                                <write file="outputFile" overwrite="true" value="${response.code}|${response.headers.getHeader('Content-Type')}" />
                                <write file="outputFile" append="true" value="|${response.content()}" />
                            </response>
                        </http>
                    </main>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
