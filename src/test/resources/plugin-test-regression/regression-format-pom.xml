<project>
    <build>
        <plugins>
            <plugin>
                <groupId>com.clmcat.maven.plugins</groupId>
                <artifactId>build-logic-maven-plugin</artifactId>
                <version>1.0-SNAPSHOT</version>
                <configuration>
                    <main>
                        <var name="csv" value="1,2,3" />
                        <file name="outputFile" path="${project.basedir}/regression-format-output.txt" />
                        <write file="outputFile" overwrite="true" value="${csv.replace(',', '|')}" />
                    </main>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
